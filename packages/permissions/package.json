  },
  "dependencies": {
    "@openfoundry/errors": "workspace:*",
    "@openfoundry/rid": "workspace:*",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/pg": "^8.11.0",
    "typescript": "~5.5.4",
    "vitest": "^3.2.0"
  },
  "peerDependencies": {
    "fastify": "^5.3.0"
  },
  "peerDependenciesMeta": {
