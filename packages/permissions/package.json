{
  "name": "@openfoundry/permissions",
  "version": "0.0.1",
  "private": true,
  "description": "Permission model supporting role-based access control for the OpenFoundry platform",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
