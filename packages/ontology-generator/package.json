{
  "name": "@openfoundry/ontology-generator",
  "version": "0.0.1",
  "private": true,
  "description": "Generates TypeScript SDK code from an OntologyIr",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@openfoundry/ontology-ir": "workspace:*",
    "@openfoundry/ontology-schema": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "license": "Apache-2.0"
}
