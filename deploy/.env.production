# =============================================================================
# OpenFoundry — Production Environment Configuration
#
# IMPORTANT: Copy this file and fill in all values marked CHANGEME before use.
# Never commit the filled-in version to source control.
# =============================================================================

# --- Database -----------------------------------------------------------------
POSTGRES_USER=openfoundry
POSTGRES_PASSWORD=CHANGEME_pg_secret_min_32_chars_here
POSTGRES_DB=openfoundry

# --- Redis --------------------------------------------------------------------
REDIS_PASSWORD=CHANGEME_redis_secret_here

# --- MinIO / S3 ---------------------------------------------------------------
MINIO_ROOT_USER=openfoundry
MINIO_ROOT_PASSWORD=CHANGEME_minio_secret_min_16_chars
S3_BUCKET=openfoundry-media
S3_REGION=us-east-1

# --- Authentication -----------------------------------------------------------
JWT_SECRET=CHANGEME_jwt_secret_min_64_chars_use_openssl_rand_base64_48
AUTH_PUBLIC_KEY=
AUTH_ISSUER=openfoundry
AUTH_AUDIENCE=openfoundry-api
OAUTH_CLIENT_ID=openfoundry-console
OAUTH_CLIENT_SECRET=CHANGEME_oauth_secret_here
TOKEN_EXPIRY_SECONDS=3600

# --- Image Registry -----------------------------------------------------------
IMAGE_REGISTRY=openfoundry
IMAGE_TAG=latest

# --- External Ports (host-mapped) ---------------------------------------------
GATEWAY_EXTERNAL_PORT=8080
CONSOLE_EXTERNAL_PORT=3000

# --- CORS ---------------------------------------------------------------------
# Comma-separated list of allowed origins. Restrict to your actual domain.
CORS_ORIGIN=https://console.openfoundry.example.com

# --- Rate Limiting ------------------------------------------------------------
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000

# --- Logging ------------------------------------------------------------------
LOG_LEVEL=warn
LOG_FORMAT=json

# --- Tracing ------------------------------------------------------------------
TRACING_ENABLED=false
TRACING_ENDPOINT=

# --- Permissions --------------------------------------------------------------
ENFORCE_PERMISSIONS=true
