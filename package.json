{
  "name": "openfoundry",
  "version": "0.0.0",
  "private": true,
  "description": "Open-source data platform with ontology-first architecture",
  "license": "Apache-2.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "format": "prettier --write .",
    "db:migrate": "node scripts/migrate.js",
    "db:seed": "node scripts/seed.js",
    "docker:up": "docker compose -f deploy/docker-compose.dev.yml up -d",
    "docker:down": "docker compose -f deploy/docker-compose.dev.yml down",
    "generate:api": "turbo run generate --filter=@openfoundry/api-types",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build --filter=./packages/* && changeset publish",
    "test:integration": "vitest run -c tests/vitest.config.ts"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "prettier": "^3.3.0",
    "turbo": "^2.5.0",
    "typescript": "~5.5.4",
    "typescript-eslint": "^8.57.0",
    "vitest": "^3.2.0"
  },
  "packageManager": "pnpm@10.27.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "pino-pretty": "^13.1.3"
  }
}
