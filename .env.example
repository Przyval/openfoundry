# =============================================================================
# OpenFoundry Environment Configuration
# Copy this file to .env and adjust values for your environment
# =============================================================================

# --- Database ---
DATABASE_URL=postgresql://openfoundry:openfoundry@localhost:5432/openfoundry

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- S3 / MinIO ---
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=openfoundry
S3_SECRET_KEY=openfoundry_dev
S3_BUCKET=openfoundry-media
S3_REGION=us-east-1

# --- Authentication ---
JWT_SECRET=change-me-in-production
OAUTH_CLIENT_ID=openfoundry-console
OAUTH_CLIENT_SECRET=change-me-in-production
TOKEN_EXPIRY_SECONDS=3600

# --- Service Ports ---
GATEWAY_PORT=8080
ONTOLOGY_PORT=8081
OBJECTS_PORT=8082
ACTIONS_PORT=8083
MULTIPASS_PORT=8084
DATASETS_PORT=8085
COMPASS_PORT=8086
ADMIN_PORT=8087
FUNCTIONS_PORT=8088
WEBHOOKS_PORT=8089
MEDIA_PORT=8090
SENTINEL_PORT=8091

# --- Console ---
CONSOLE_PORT=3000
VITE_API_BASE_URL=http://localhost:8080

# --- AIP / LLM ---
AIP_PORT=8092
# Set one of these to enable LLM features (auto-detected):
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# OLLAMA_URL=http://localhost:11434

# --- Permissions ---
ENFORCE_PERMISSIONS=false

# --- Logging ---
LOG_LEVEL=info
LOG_FORMAT=json

# --- Tracing ---
TRACING_ENABLED=false
TRACING_ENDPOINT=http://localhost:9411/api/v2/spans
